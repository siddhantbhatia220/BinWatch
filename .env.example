# Environment Variables Example File
# Rename this file to .env and replace the values with your own.

# Port for the Node.js server (Default: 3000)
PORT=3000

# MongoDB Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ecobin?retryWrites=true&w=majority

# Secret key for signing JWT tokens (use a long, random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Email address of the admin user (gets 'admin' role automatically on registration)
ADMIN_EMAIL=admin@ecobin.com

# Resend API Key for sending email alerts (optional, but required for email notifications)
RESEND_API_KEY=re_your_resend_api_key_here

# The email address that alerts will be sent FROM (must be verified in your Resend account)
FROM_EMAIL=alerts@yourdomain.com


GOOGLE_MAPS_API_KEY=yor_googlemaps_api_key