{
  "env": {
    "node": true,
    "commonjs": true,
    "es2021": true,
    "browser": true
  },
  "extends": [
    "eslint:recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": "warn",
    "quotes": ["error", "single", { "avoidEscape": true }]
  }
}
